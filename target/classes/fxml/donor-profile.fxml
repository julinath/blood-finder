<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<BorderPane xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="bloodfinder.controller.DonorProfileController"
            prefWidth="850" prefHeight="620">

    <!-- Header -->
    <top>
        <HBox styleClass="header" spacing="15" alignment="CENTER_LEFT">
            <padding><Insets top="12" right="20" bottom="12" left="20"/></padding>
            <Button text="← Back" onAction="#goBack"
                    style="-fx-background-color: rgba(255,255,255,0.2); -fx-text-fill: white;
                           -fx-background-radius: 6; -fx-cursor: hand; -fx-padding: 8 14;"/>
            <Label text="Donor Profile" styleClass="header-title"/>
        </HBox>
    </top>

    <!-- Content -->
    <center>
        <ScrollPane fitToWidth="true" style="-fx-background-color: #F5F5F5; -fx-background: #F5F5F5;">
            <VBox spacing="0">

                <!-- Profile header (red gradient) -->
                <HBox styleClass="profile-header" spacing="25" alignment="CENTER_LEFT">
                    <padding><Insets top="30" right="30" bottom="30" left="30"/></padding>

                    <Label fx:id="lblBloodTypeBig"
                           style="-fx-font-size: 34px; -fx-font-weight: bold; -fx-text-fill: white;
                                  -fx-background-color: rgba(0,0,0,0.25); -fx-background-radius: 50;
                                  -fx-padding: 14 20; -fx-min-width: 80; -fx-alignment: center;"/>

                    <VBox spacing="8">
                        <Label fx:id="lblDonorName" styleClass="profile-name"/>
                        <Label fx:id="lblDonorLocation" styleClass="profile-location"/>
                        <Label fx:id="lblAvailability"/>
                    </VBox>
                </HBox>

                <!-- Stats and actions -->
                <VBox spacing="18" style="-fx-background-color: #F5F5F5;">
                    <padding><Insets top="20" right="25" bottom="25" left="25"/></padding>

                    <!-- Stats row -->
                    <HBox spacing="15">
                        <VBox styleClass="card" HBox.hgrow="ALWAYS" alignment="CENTER" spacing="6">
                            <padding><Insets top="18" right="10" bottom="18" left="10"/></padding>
                            <Label fx:id="lblDonationCount"
                                   style="-fx-font-size: 30px; -fx-font-weight: bold; -fx-text-fill: #C0392B;"/>
                            <Label text="Total Donations" style="-fx-text-fill: #7F8C8D; -fx-font-size: 12px;"/>
                        </VBox>
                        <VBox styleClass="card" HBox.hgrow="ALWAYS" alignment="CENTER" spacing="6">
                            <padding><Insets top="18" right="10" bottom="18" left="10"/></padding>
                            <Label fx:id="lblLastDonation"
                                   style="-fx-font-size: 13px; -fx-font-weight: bold; -fx-text-fill: #2C3E50;"
                                   wrapText="true" alignment="CENTER"/>
                            <Label text="Last Donation" style="-fx-text-fill: #7F8C8D; -fx-font-size: 12px;"/>
                        </VBox>
                        <VBox styleClass="card" HBox.hgrow="ALWAYS" alignment="CENTER" spacing="6">
                            <padding><Insets top="18" right="10" bottom="18" left="10"/></padding>
                            <Label fx:id="lblDaysUntil"
                                   style="-fx-font-size: 13px; -fx-font-weight: bold; -fx-text-fill: #2C3E50;"/>
                            <Label text="Days Until Available" style="-fx-text-fill: #7F8C8D; -fx-font-size: 12px;"/>
                        </VBox>
                    </HBox>

                    <!-- Request blood card -->
                    <VBox styleClass="card" spacing="12">
                        <Label text="Blood Request পাঠান" styleClass="label-section"/>
                        <Button fx:id="btnRequestBlood" text="🩸  Request Blood"
                                onAction="#handleRequestBlood" prefWidth="220"
                                style="-fx-font-size: 14px; -fx-padding: 11 24;"/>
                        <Label fx:id="lblRequestNote"
                               style="-fx-text-fill: #7F8C8D; -fx-font-size: 12px;" wrapText="true"/>
                    </VBox>
                </VBox>
            </VBox>
        </ScrollPane>
    </center>
</BorderPane>
