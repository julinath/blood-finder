<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<BorderPane xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="bloodfinder.controller.DonorSearchController"
            prefWidth="1050" prefHeight="700">

    <!-- Header -->
    <top>
        <HBox styleClass="header" spacing="15" alignment="CENTER_LEFT">
            <padding><Insets top="12" right="20" bottom="12" left="20"/></padding>
            <Label text="🩸 Blood Finder" styleClass="header-title"/>
            <Region HBox.hgrow="ALWAYS"/>
            <Label fx:id="lblNavUser" styleClass="header-user"/>
            <Button fx:id="btnNavAction" text="Login" onAction="#handleNavAction"
                    style="-fx-background-color: rgba(0,0,0,0.2); -fx-text-fill: white;
                           -fx-background-radius: 6; -fx-cursor: hand; -fx-padding: 8 16;"/>
        </HBox>
    </top>

    <!-- Left: Filter panel -->
    <left>
        <VBox styleClass="filter-panel" spacing="14">
            <padding><Insets top="20" right="18" bottom="20" left="18"/></padding>
            <Label text="Search Filters" styleClass="label-section"/>
            <Separator/>

            <VBox spacing="6">
                <Label text="Blood Type" style="-fx-font-weight: bold; -fx-text-fill: #2C3E50;"/>
                <ComboBox fx:id="cmbBloodType" maxWidth="Infinity"/>
            </VBox>

            <VBox spacing="6">
                <Label text="Location" style="-fx-font-weight: bold; -fx-text-fill: #2C3E50;"/>
                <TextField fx:id="txtLocation" promptText="Area / City"/>
            </VBox>

            <CheckBox fx:id="chkAvailableOnly" text="Available only"
                      style="-fx-text-fill: #2C3E50;"/>

            <Button text="🔍  Search" onAction="#handleSearch" maxWidth="Infinity"/>
            <Button text="Clear" onAction="#handleClear" maxWidth="Infinity"
                    style="-fx-background-color: #95A5A6; -fx-text-fill: white; -fx-background-radius: 6;
                           -fx-cursor: hand; -fx-padding: 8 14;"/>

            <Separator/>
            <Label fx:id="lblResultCount" style="-fx-text-fill: #7F8C8D; -fx-font-size: 12px;"
                   wrapText="true"/>
        </VBox>
    </left>

    <!-- Center: Donor list -->
    <center>
        <VBox style="-fx-background-color: #F5F5F5;">
            <padding><Insets top="20" right="20" bottom="20" left="20"/></padding>
            <Label text="Donors" styleClass="label-section"/>
            <Region prefHeight="10"/>
            <ScrollPane VBox.vgrow="ALWAYS" fitToWidth="true"
                        style="-fx-background-color: transparent; -fx-background: transparent;">
                <VBox fx:id="vboxDonors" spacing="12">
                    <padding><Insets right="5"/></padding>
                </VBox>
            </ScrollPane>
        </VBox>
    </center>

</BorderPane>
