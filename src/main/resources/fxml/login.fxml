<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<HBox xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="bloodfinder.controller.LoginController"
      prefWidth="820" prefHeight="540">

    <!-- Left: Red branding panel -->
    <VBox styleClass="login-left" alignment="CENTER" spacing="18">
        <padding><Insets top="50" right="40" bottom="50" left="40"/></padding>
        <Label text="🩸" style="-fx-font-size: 55px;"/>
        <Label text="Blood Finder" style="-fx-font-size: 30px; -fx-font-weight: bold; -fx-text-fill: white;"/>
        <Label text="Find the right person&#10;when you need blood"
               style="-fx-font-size: 14px; -fx-text-fill: rgba(255,255,255,0.85); -fx-text-alignment: center;"
               wrapText="true" alignment="CENTER"/>
        <Separator style="-fx-background-color: rgba(255,255,255,0.3);" maxWidth="120"/>
        <Label text="Free · Fast · Reliable"
               style="-fx-font-size: 12px; -fx-text-fill: rgba(255,255,255,0.6);"/>
    </VBox>

    <!-- Right: Login form -->
    <VBox HBox.hgrow="ALWAYS" alignment="CENTER" spacing="14"
          style="-fx-background-color: white;">
        <padding><Insets top="50" right="60" bottom="50" left="60"/></padding>

        <Label text="Welcome!" style="-fx-font-size: 24px; -fx-font-weight: bold; -fx-text-fill: #2C3E50;"/>
        <Label text="Login to your account"
               style="-fx-text-fill: #7F8C8D; -fx-font-size: 13px;"/>

        <Region prefHeight="10"/>

        <VBox spacing="6" maxWidth="320">
            <Label text="Email" style="-fx-font-weight: bold; -fx-text-fill: #2C3E50;"/>
            <TextField fx:id="emailField" promptText="email@example.com" prefWidth="320"/>
        </VBox>

        <VBox spacing="6" maxWidth="320">
            <Label text="Password" style="-fx-font-weight: bold; -fx-text-fill: #2C3E50;"/>
            <PasswordField fx:id="passwordField" promptText="Password" prefWidth="320"/>
        </VBox>

        <Label fx:id="errorLabel" wrapText="true" maxWidth="320"/>

        <Button text="Login" onAction="#handleLogin" prefWidth="320" style="-fx-font-size: 14px;"/>

        <Separator maxWidth="320"/>

        <HBox alignment="CENTER" spacing="5">
            <Label text="Don't have an account?" style="-fx-text-fill: #7F8C8D;"/>
            <Hyperlink text="Register" onAction="#goToRegister"/>
        </HBox>

        <Hyperlink text="Browse donors without login →" onAction="#browseAsGuest"
                   style="-fx-text-fill: #7F8C8D; -fx-font-size: 12px;"/>
    </VBox>
</HBox>
