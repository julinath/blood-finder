<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<StackPane xmlns:fx="http://javafx.com/fxml/1"
           fx:controller="bloodfinder.controller.BecomeDonorController"
           prefWidth="680" prefHeight="480"
           style="-fx-background-color: #F5F5F5;">

    <VBox alignment="CENTER">
        <VBox styleClass="card" maxWidth="460" spacing="16">
            <padding><Insets top="35" right="40" bottom="35" left="40"/></padding>

            <HBox alignment="CENTER_LEFT" spacing="12">
                <Button text="← Back" onAction="#goBack"
                        style="-fx-background-color: #F0F0F0; -fx-background-radius: 6;
                               -fx-cursor: hand; -fx-padding: 7 14;"/>
                <Label text="🩸 Become a Donor" styleClass="label-title"/>
            </HBox>

            <Label text="Enter your blood type and information"
                   style="-fx-text-fill: #7F8C8D; -fx-font-size: 13px;"/>

            <Separator/>

            <VBox spacing="6">
                <Label text="Blood Type *" style="-fx-font-weight: bold;"/>
                <ComboBox fx:id="cmbBloodType" promptText="Select blood type" maxWidth="Infinity"/>
            </VBox>

            <VBox spacing="6">
                <Label text="Last Donation Date" style="-fx-font-weight: bold;"/>
                <DatePicker fx:id="lastDonationPicker"
                            promptText="When did you last donate?" maxWidth="Infinity"/>
                <Label text="* Leave empty if you have never donated before"
                       style="-fx-text-fill: #95A5A6; -fx-font-size: 11px;"/>
            </VBox>

            <Label fx:id="statusLabel" wrapText="true" maxWidth="380"/>

            <HBox spacing="12">
                <Button text="Register as Donor" onAction="#handleBecomeDonor"
                        HBox.hgrow="ALWAYS" maxWidth="Infinity"
                        style="-fx-font-size: 14px; -fx-padding: 11 0;"/>
                <Button text="Cancel" onAction="#goBack"
                        style="-fx-background-color: #95A5A6; -fx-text-fill: white;
                               -fx-background-radius: 6; -fx-cursor: hand; -fx-padding: 11 20;"/>
            </HBox>
        </VBox>
    </VBox>
</StackPane>
